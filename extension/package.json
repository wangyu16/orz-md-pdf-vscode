{
  "name": "orz-md-pdf",
  "displayName": "ORZ MD-PDF Editor",
  "description": "Edit and preview .md.pdf files — valid PDFs with embedded Markdown source.",
  "version": "1.0.0",
  "author": {
    "name": "Yu Wang",
    "email": "yuwang@orz.how"
  },
  "engines": { "vscode": "^1.88.0" },
  "publisher": "yuwang26",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangyu16/orz-md-pdf-vscode.git"
  },
  "categories": ["Other"],
  "license": "MIT",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCustomEditor:orzMdPdf.editor",
    "onCommand:orzMdPdf.newFile",
    "onCommand:orzMdPdf.convertMd",
    "onCommand:orzMdPdf.exportPdf",
    "onCommand:orzMdPdf.togglePreview"
  ],
  "scripts": {
    "build": "node build.js",
    "watch": "node build.js --watch",
    "vscode:prepublish": "node build.js"
  },
  "contributes": {
    "languages": [
      {
        "id": "orz-md-source",
        "aliases": ["Markdown Source"],
        "extensions": [".orz-md"]
      }
    ],
    "grammars": [
      {
        "language": "orz-md-source",
        "scopeName": "source.orz-md",
        "path": "./syntaxes/orz-md.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[orz-md-source]": {
        "editor.inlineSuggest.enabled": false
      }
    },
    "customEditors": [
      {
        "viewType": "orzMdPdf.editor",
        "displayName": "MD-PDF Editor",
        "selector": [{ "filenamePattern": "*.md.pdf" }],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "orzMdPdf.newFile",
        "title": "MD-PDF: New File"
      },
      {
        "command": "orzMdPdf.convertMd",
        "title": "MD-PDF: Convert .md to .md.pdf"
      },
      {
        "command": "orzMdPdf.exportPdf",
        "title": "MD-PDF: Export as Pure PDF"
      },
      {
        "command": "orzMdPdf.togglePreview",
        "title": "MD-PDF: Toggle Preview Panel"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "orzMdPdf.convertMd",
          "when": "resourceExtname == '.md'",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "orzMdPdf.exportPdf",
          "when": "activeCustomEditorId == 'orzMdPdf.editor'"
        },
        {
          "command": "orzMdPdf.togglePreview",
          "when": "activeCustomEditorId == 'orzMdPdf.editor'"
        }
      ]
    }
  },
  "extensionDependencies": [
    "yuwang26.orz-md-preview"
  ],
  "devDependencies": {
    "@types/vscode": "^1.88.0",
    "esbuild": "^0.21.0"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "mermaid": "^11.13.0",
    "node-html-parser": "^7.1.0",
    "pagedjs": "^0.4.3",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^22.0.0",
    "smiles-drawer": "^2.2.1"
  }
}
