{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-extension",
            "type": "shell",
            "command": "node build.js",
            "options": {
                "cwd": "${workspaceFolder}/extension"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "watch-extension",
            "type": "shell",
            "command": "node build.js --watch",
            "options": {
                "cwd": "${workspaceFolder}/extension"
            },
            "isBackground": true,
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
